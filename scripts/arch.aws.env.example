# ARCH AWS runtime overlay for OCI deployment.
# Copy this file and pass it to:
#   ./scripts/deploy-oci-stack.sh --aws-env-file /path/to/arch.aws.env

# Required to switch from static demo graph to live AWS discovery.
ARCH_DISCOVERY_MODE=aws
ARCH_AWS_REGION=us-east-1

# Preferred: assume a least-privilege role.
ARCH_AWS_ROLE_ARN=arn:aws:iam::123456789012:role/arch-readonly
ARCH_AWS_SESSION_NAME=arch-oci
ARCH_AWS_EXTERNAL_ID=
ARCH_AWS_VALIDATE_ON_START=true

# Bootstrap credentials for the AWS SDK default credential chain.
# Use temporary credentials (no permanent keys).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
